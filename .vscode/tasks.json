{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "cmake build oscilloscope_qt",
            "type": "shell",
            "command": "cmake --build build --target oscilloscope_qt",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "build-controller",
            "type": "shell",
            "osx": {
                "command": "gcc *.c libftd2xx.a -I. -L. -framework CoreFoundation -framework IOKit -o controller -g"
            },
            "windows": {
                "command": "gcc *.c -lftd2xx -o controller.exe -g"
            },
            "problemMatcher": [],
            "group": "build"
        },
        {
            "type": "cppbuild",
            "label": "C/C++: clang build active file",
            "command": "/usr/bin/clang",
            "args": [
                "-fcolor-diagnostics",
                "-fansi-escape-codes",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by the debugger."
        }
    ]
}